@page
@{
    ViewData["Title"] = "Home";
    var isAuthed = User?.Identity?.IsAuthenticated ?? false;
}

<div class="bg-primary text-white rounded-4 p-5 mb-4 shadow-sm">
    <div class="container-fluid py-3">
        <h1 class="display-5 fw-bold">RecordFlow</h1>
        <p class="col-md-8 fs-5">
            A simple, secure way to create, search, and manage datasets.
        </p>

        @if (!isAuthed)
        {
            <div class="mt-4">
                <a class="btn btn-light btn-lg me-2"
                   asp-area="Identity" asp-page="/Account/Register">
                    Get Started
                </a>
                <a class="btn btn-outline-light btn-lg"
                   asp-area="Identity" asp-page="/Account/Login">
                    Login
                </a>
            </div>
        }
        else
        {
            <div class="mt-4 d-flex gap-2 flex-wrap">
                <a class="btn btn-light btn-lg" asp-page="/Dashboard">Dashboard</a>
                <a class="btn btn-outline-light btn-lg" asp-page="/Datasets/Create">Create Dataset</a>
            </div>
        }
    </div>
</div>

<div class="row g-4">
    <div class="col-md-4">
        <div class="card h-100 border-0 shadow-sm">
            <div class="card-body">
                <h5 class="card-title text-primary">Organize</h5>
                <p class="card-text text-muted">
                    Create datasets with clear names and descriptions so your data stays structured.
                </p>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card h-100 border-0 shadow-sm">
            <div class="card-body">
                <h5 class="card-title text-success">Search Fast</h5>
                <p class="card-text text-muted">
                    Use wildcard search like <code>roof*</code> or <code>*clean*</code> to find data instantly.
                </p>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card h-100 border-0 shadow-sm">
            <div class="card-body">
                <h5 class="card-title text-dark">Secure</h5>
                <p class="card-text text-muted">
                    Authentication protects your data and keeps access restricted to authorized users.
                </p>
            </div>
        </div>
    </div>
</div>